{
  "name": "bliver",
  "version": "1.0.0",
  "description": "Location sharing full-stack application",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "start": "node backend/index.js",
    "render-build": "cd backend && npm install && cd ../frontend && npm install && npm run build",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4"
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx,js,jsx}": [
      "cd frontend && npx tsc --noEmit"
    ],
    "backend/**/*.js": [
      "cd backend && npx jest --forceExit --passWithNoTests"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3"
  }
}
