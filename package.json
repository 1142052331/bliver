{
  "name": "bliver",
  "version": "1.0.0",
  "description": "Location sharing full-stack application",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check:node": "node -e \"const major=Number(process.versions.node.split('.')[0]); if(major!==24){console.error('Bliver requires Node.js 24.x; found '+process.version); process.exit(1)}\"",
    "dev": "concurrently -n frontend,backend -c blue,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "start": "node backend/index.js",
    "render-build": "npm run check:node && npm --prefix backend ci --omit=dev --no-audit --no-fund && npm --prefix frontend ci --include=dev --no-audit --no-fund && npm --prefix frontend run build",
    "verify:release": "node scripts/verify-release.mjs",
    "smoke:release": "node scripts/release-smoke.mjs",
    "test:release-tools": "node --test scripts/*.test.mjs",
    "prepare": "husky",
    "dev:v2": "concurrently -n web,api -c blue,green \"npm run dev --workspace @bliver/web\" \"npm run dev --workspace @bliver/api\"",
    "build:v2": "npm run build --workspaces --if-present",
    "test:v2": "vitest run --config vitest.config.ts",
    "typecheck:v2": "npm run typecheck --workspaces --if-present && tsc -p scripts/tsconfig.json",
    "lint:v2": "npm run lint --workspaces --if-present",
    "architecture:check": "tsx scripts/v2-architecture-check.ts",
    "db:v2:up": "docker compose -f infra/docker-compose.postgres.yml up -d",
    "db:v2:migrate": "tsx apps/api/src/platform/db/migrate.ts",
    "db:v2:seed": "tsx apps/api/src/platform/db/seed.ts",
    "smoke:v2": "tsx scripts/v2-foundation-smoke.ts",
    "perf:v2": "tsx scripts/perf/run.ts",
    "security:v2": "tsx scripts/security/run.ts",
    "cap:v2:smoke": "tsx scripts/capacitor/smoke.ts",
    "verify:v2-foundation": "npm run architecture:check && npm run lint:v2 && npm run typecheck:v2 && npm run test:v2 && npm run build:v2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "node -e \"process.exit(0)\""
  },
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "npm@11.13.0",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/node": "^24.10.1",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "testcontainers": "^12.0.4",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4"
  }
}
