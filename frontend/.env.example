# API and Socket.IO use the current origin by default. Set these only for split-origin deployments.
VITE_API_URL=
VITE_SOCKET_URL=

# Optional public build-time configuration
VITE_OWM_API_KEY=
VITE_SENTRY_DSN=
VITE_DEPLOY_ENV=development
# Release builds inject an immutable commit SHA; leave blank for local development.
VITE_RELEASE_SHA=
