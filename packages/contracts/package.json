{
  "name": "@bliver/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^9.0.0",
    "@bliver/domain": "0.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint --config ../config/eslint.base.mjs . --max-warnings 0",
    "contracts:openapi": "tsx src/generate-openapi.ts && openapi-typescript ../../artifacts/openapi/v2.json -o generated/v2.d.ts"
  }
}
